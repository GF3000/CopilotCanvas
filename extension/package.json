{
  "name": "canvas-for-copilot",
  "displayName": "Canvas for Copilot",
  "description": "Renders Copilot CLI diagrams as an interactive Cytoscape canvas tab.",
  "version": "0.1.0",
  "private": true,
  "publisher": "canvas-for-copilot",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GF3000/CopilotCanvas"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "canvasForCopilot.openCanvas",
        "title": "Canvas for Copilot: Open Canvas"
      }
    ]
  },
  "dependencies": {
    "@canvas/shared": "*",
    "@canvas/server": "*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.cjs --tsconfig=tsconfig.json && node scripts/copy-canvas.mjs && node scripts/copy-skills.mjs",
    "dev": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.cjs --tsconfig=tsconfig.json --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  }
}
