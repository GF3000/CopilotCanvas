{
  "name": "canvas-for-copilot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Live interactive diagrams from Copilot CLI, rendered as a VS Code canvas tab.",
  "workspaces": [
    "shared",
    "server",
    "canvas",
    "extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently -n canvas,server,ext -c blue,green,magenta \"npm run dev -w @canvas/canvas\" \"npm run dev -w @canvas/server\" \"npm run dev -w @canvas/extension\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "@types/vscode": "^1.90.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
