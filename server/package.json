{
  "name": "@canvas/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "dependencies": {
    "@canvas/shared": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --tsconfig=tsconfig.json",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --tsconfig=tsconfig.json --watch"
  }
}
